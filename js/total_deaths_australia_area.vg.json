{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Deaths Over Time by Gender (Australia)",

  "width": 600,
  "height": 400,

  "data": {
    "url": "https://raw.githubusercontent.com/lnic0029/FIT2179_A2/main/data/cleaned_total_deaths_australia.csv",
    "format": {
      "type": "csv"
    }
  },

  "transform": [
    {
      "filter": "datum.gender != 'total'"
    }
  ],

  "mark": {
    "type": "area",
    "interpolate": "monotone",
    "opacity": 0.8
  },

  "encoding": {
    "x": {
      "field": "year",
      "type": "temporal",
      "title": "Year"
    },

    "y": {
      "aggregate": "sum",
      "field": "deaths",
      "type": "quantitative",
      "title": "Total Deaths",
      "stack": "zero"
    },

    "color": {
      "field": "gender",
      "type": "nominal",
      "title": "Gender",
      "scale": {
        "domain": ["males", "females"],
        "range": ["#f58518", "#9d18f5"]
      }
    },

    "tooltip": [
      {"field": "year", "type": "temporal", "title": "Year"},
      {"field": "gender", "type": "nominal", "title": "Gender"},
      {"field": "deaths", "type": "quantitative", "title": "Deaths", "format": ","}
    ]
  },
  "config": {
  "view": {
    "stroke": null
  }
  }
}