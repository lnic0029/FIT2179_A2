{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Categories of Leading Causes of Death (2021)",
  "width": "container",
  "height": 625,

  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/3_choropleth_map/js/ne_110m_admin_0_countries.topojson",
    "format": { "type": "topojson", "feature": "ne_110m_admin_0_countries" }
  },
  "projection": { "type": "equalEarth" },
  "layer": [
    {
      "transform": [
        {
          "calculate": "'Data is not available in ' + datum.properties.NAME",
          "as": "note"
        }
      ],
      "mark": { "type": "geoshape", "fill": "lightgray", "stroke": "white" },
      "encoding": { "tooltip": { "field": "note" } }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/7_others/oceans.topojson",
        "format": { "type": "topojson", "feature": "oceans" }
      },
      "mark": { "type": "geoshape", "fill": "#94d7f1" }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/2_symbol_map/js/WorldMapWithGraticules.topojson",
        "format": { "type": "topojson", "feature": "ne_110m_graticules_30" }
      },
      "mark": { "type": "geoshape", "fill": null, "stroke": "lightgray" }
    },
    {
      "transform": [
        {
          "lookup": "properties.ADM0_A3",
          "from": {
            "data": {
              "url": "https://raw.githubusercontent.com/lnic0029/FIT2179_A2/refs/heads/main/data/cleaned_leading_causes_2021.csv"
            },
            "key": "iso3",
            "fields": [
              "country",
              "largest_major_category",
              "percentage_of_total_deaths"
            ]
          }
        }
      ],

      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 0.5
      },

      "encoding": {
        "color": {
          "legend": { "orient": "bottom" },
          "field": "largest_major_category",
          "type": "nominal",
          "title": "Leading Cause Category",
          "scale": {
            "domain": [
              "Noncommunicable diseases",
              "Communicable, maternal, perinatal and nutritional conditions",
              "Injuries",
              "nan"
            ],
            "range": ["#1f77b4", "#1ba31e", "#ffffff", "000000"]
          }
        },

        "opacity": {
          "legend": null,
          "field": "percentage_of_total_deaths",
          "type": "quantitative",
          "scale": {
            "domain": [0, 100],
            "range": [0.2, 1]
          }
        },

        "tooltip": [
          {
            "field": "properties.NAME",
            "type": "nominal",
            "title": "Country"
          },
          {
            "field": "largest_major_category",
            "type": "nominal",
            "title": "Category"
          },
          {
            "field": "percentage_of_total_deaths",
            "type": "quantitative",
            "title": "Percentage of Total Deaths"
          }
        ]
      }
    },

    {
      "data": {
        "url": "https://raw.githubusercontent.com/FIT3179/Vega-Lite/main/7_others/oceans.topojson",
        "format": {
          "type": "topojson",
          "feature": "oceans"
        }
      },

      "mark": {
        "type": "geoshape",
        "fill": "#a6dff5"
      }
    }
  ],

  "config": {
    "view": {
      "stroke": null
    }
  }
}
