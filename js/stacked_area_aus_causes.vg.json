{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Mortality by Cause Group (Australia, 2014–2024)",
  "width": 600,
  "height": 400,

  "data": {
    "url": "../data/australia_grouped_causes.csv"
  },

  "transform": [
    { "filter": "datum.sex == 'persons'" },
    { "calculate": "toNumber(datum.year)", "as": "year_num" }
  ],

  "mark": {
    "type": "area",
    "opacity": 0.8
  },

  "encoding": {
    "x": {
      "field": "year_num",
      "type": "quantitative",
      "title": "Year",
      "sort": "ascending"
    },

    "y": {
      "field": "deaths",
      "type": "quantitative",
      "stack": "zero",
      "title": "Deaths"
    },

    "color": {
      "field": "grouped_cause",
      "type": "nominal",
      "title": "Cause Group"
    },

    "tooltip": [
      { "field": "year", "type": "ordinal" },
      { "field": "grouped_cause", "type": "nominal" },
      { "field": "deaths", "type": "quantitative" }
    ]
  }
}
