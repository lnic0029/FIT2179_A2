{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Deaths by Cause Group (2014–2024)",
  "width": "container",
  "height": 400,
  "autosize": {
    "type": "fit-x",
    "contains": "padding"
  },

  "data": {
    "url": "https://raw.githubusercontent.com/lnic0029/FIT2179_A2/refs/heads/main/data/australia_grouped_causes.csv"
  },

  "transform": [
    { "filter": "datum.sex == 'persons'" },
    { "calculate": "toNumber(datum.year)", "as": "year_num" }
  ],

  "mark": {
    "type": "area",
    "opacity": 0.8
  },

  "encoding": {
    "x": {
      "field": "year_num",
      "type": "quantitative",
      "title": "Year",
      "axis": {
        "format": "d"
      }
    },

    "y": {
      "field": "deaths",
      "type": "quantitative",
      "stack": "zero"
    },

    "color": {
      "field": "grouped_cause",
      "type": "nominal",
      "title": "Cause Group",
      "scale": {
        "domain": [
          "Cancer",
          "Heart disease",
          "Injuries",
          "Other",
          "Respiratory diseases"
        ],
        "range": ["#731fb4", "#f51818", "#e4ca03", "#8a8a8a", "#e17c09"]
      }
    },

    "tooltip": [
      { "field": "year", "type": "ordinal", "title": "Year" },
      { "field": "grouped_cause", "type": "nominal", "title": "Grouped Cause" },
      { "field": "deaths", "type": "quantitative", "title": "Deaths" }
    ]
  }
}
