{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 200,
  "autosize": {
    "type": "fit-x",
    "contains": "padding"
  },
  "title": "Global Causes of Death Over Time (Normalized)",

  "data": {
    "url": "https://raw.githubusercontent.com/lnic0029/FIT2179_A2/refs/heads/main/data/merged_all_years_categories.csv"
  },

  "transform": [
    {
      "filter": "datum.sex === 'persons'"
    },
    {
      "calculate": "toNumber(datum.year)",
      "as": "year"
    }
  ],

  "mark": "area",

  "encoding": {
    "x": {
      "field": "year",
      "type": "quantitative",
      "title": "Year",
      "scale": {
        "domain": [2000, 2021]
      },
      "axis": {
        "format": "d"
      }
    },

    "y": {
      "aggregate": "sum",
      "field": "number_of_deaths",
      "type": "quantitative",
      "stack": "normalize",
      "axis": { "format": ".0%" },
      "title": "Share of Deaths"
    },

    "color": {
      "field": "major_category",
      "type": "nominal",
      "title": "Cause of Death",
      "scale": {
        "domain": [
          "Noncommunicable diseases",
          "Communicable, maternal, perinatal and nutritional conditions",
          "Injuries"
        ],
        "range": ["#1f77b4", "#1ba31e", "#e4ca03"]
      },
      "legend": null
    },

    "tooltip": [
      { "field": "year", "type": "ordinal" },
      {
        "field": "major_category",
        "type": "nominal",
        "title": "Major Category"
      },
      {
        "aggregate": "sum",
        "field": "number_of_deaths",
        "type": "quantitative",
        "title": "Number of Deaths"
      }
    ]
  }
}
