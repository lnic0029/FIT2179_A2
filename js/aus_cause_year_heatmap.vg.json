{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 650,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "title": "Top Causes of Death per Year in Australia",

  "data": {
    "url": "https://raw.githubusercontent.com/lnic0029/FIT2179_A2/refs/heads/main/data/aust_top15_causes.csv"
  },

  "transform": [
    {
      "filter": "datum.sex === 'persons'"
    },

    {
      "window": [
        {
          "op": "sum",
          "field": "deaths",
          "as": "yearly_deaths"
        }
      ],
      "groupby": ["year", "cause"]
    },

    {
      "window": [
        {
          "op": "rank",
          "as": "rank"
        }
      ],
      "groupby": ["year"],
      "sort": [{ "field": "yearly_deaths", "order": "descending" }]
    }
  ],

  "resolve": {
    "scale": {
      "color": "independent"
    }
  },

  "layer": [
    {
      "transform": [{ "filter": "datum.rank === 1" }],

      "mark": {
        "type": "rect",
        "stroke": "black",
        "strokeWidth": 2
      },

      "encoding": {
        "x": { "field": "year", "type": "ordinal" },
        "y": { "field": "cause", "type": "nominal" },

        "color": {
          "field": "yearly_deaths",
          "type": "quantitative",
          "scale": {
            "range": ["#4f4f4f", "#353535", "#202020", "#131313"]
          },
          "legend": {
            "title": "Top Death Cause Each Year"
          }
        },
        "tooltip": [
          { "field": "year", "type": "ordinal" },
          { "field": "cause", "type": "nominal" },
          {
            "field": "yearly_deaths",
            "type": "quantitative",
            "title": "Deaths"
          },
          {
            "field": "rank",
            "type": "quantitative",
            "title": "Rank (per year)"
          }
        ]
      }
    },

    {
      "transform": [{ "filter": "datum.rank > 1" }],

      "mark": "rect",

      "encoding": {
        "x": { "field": "year", "type": "ordinal" },
        "y": { "field": "cause", "type": "nominal" },

        "color": {
          "field": "yearly_deaths",
          "type": "quantitative",
          "scale": {
            "scheme": "blues"
          },
          "title": "Deaths"
        },
        "tooltip": [
          { "field": "year", "type": "ordinal" },
          { "field": "cause", "type": "nominal" },
          {
            "field": "yearly_deaths",
            "type": "quantitative",
            "title": "Deaths"
          },
          {
            "field": "rank",
            "type": "quantitative",
            "title": "Rank (per year)"
          }
        ]
      }
    }
  ]
}
