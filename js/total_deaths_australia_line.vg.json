{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Deaths Over Time by Gender (Australia)",
  "width": "container",
  "height": 200,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/lnic0029/FIT2179_A2/refs/heads/main/data/cleaned_total_deaths_australia.csv",
    "format": {
      "type": "csv"
    }
  },
  "mark": {
    "type": "line",
    "point": true
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "temporal",
      "title": "Year"
    },
    "y": {
      "field": "deaths",
      "type": "quantitative",
      "title": "Total Deaths"
    },
    "color": {
      "field": "gender",
      "type": "nominal",
      "title": "Gender",
      "scale": {
        "domain": ["males", "females"],
        "range": ["#f51818", "#f518c9"]
      }
    },
    "tooltip": [
      { "field": "year", "type": "temporal" },
      { "field": "gender", "type": "nominal" },
      { "field": "deaths", "type": "quantitative" }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    }
  }
}
