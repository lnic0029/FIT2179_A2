{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 400,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "title": "Top 10 Causes of Death",

  "data": {
    "url": "../data/australia_cause_time.csv"
  },

  "transform": [
    {
      "filter": "datum.sex === 'persons'"
    },
    {
      "aggregate": [{ "op": "sum", "field": "deaths", "as": "total_deaths" }],
      "groupby": ["cause"]
    },
    {
      "window": [{ "op": "rank", "as": "rank" }],
      "sort": [{ "field": "total_deaths", "order": "descending" }]
    },
    {
      "filter": "datum.rank <= 10"
    }
  ],

  "mark": "bar",

  "encoding": {
    "y": {
      "field": "cause",
      "type": "nominal",
      "sort": "-x",
      "title": "Cause"
    },

    "x": {
      "field": "total_deaths",
      "type": "quantitative",
      "title": "Total Deaths"
    },

    "tooltip": [
      { "field": "cause", "type": "nominal" },
      { "field": "total_deaths", "type": "quantitative" }
    ]
  }
}
