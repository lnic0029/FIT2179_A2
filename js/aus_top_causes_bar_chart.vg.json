{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 350,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "title": "Top Causes of Death (2021)",

  "data": {
    "url": "https://raw.githubusercontent.com/lnic0029/FIT2179_A2/refs/heads/main/data/australia_cause_time.csv"
  },

  "transform": [
    {
      "filter": "datum.sex === 'persons'"
    },
    {
      "aggregate": [{ "op": "sum", "field": "deaths", "as": "total_deaths" }],
      "groupby": ["cause"]
    },
    {
      "window": [{ "op": "rank", "as": "rank" }],
      "sort": [{ "field": "total_deaths", "order": "descending" }]
    },
    {
      "filter": "datum.rank <= 10"
    }
  ],

  "mark": "bar",

  "encoding": {
    "y": {
      "field": "cause",
      "type": "nominal",
      "sort": "-x",
      "title": "Cause",
      "axis": {
        "labelLimit": 150
      }
    },

    "x": {
      "field": "total_deaths",
      "type": "quantitative",
      "title": "Total Deaths"
    },
    "color": {
      "value": "#1f77b4"
    },

    "tooltip": [
      { "field": "cause", "type": "nominal", "title": "Cause" },
      {
        "field": "total_deaths",
        "type": "quantitative",
        "title": "Number of Deaths"
      }
    ]
  }
}
