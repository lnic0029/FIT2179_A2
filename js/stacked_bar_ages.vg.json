{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 350,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "data": {
    "url": "https://raw.githubusercontent.com/lnic0029/FIT2179_A2/refs/heads/main/data/global_age_causes_2021.csv"
  },
  "transform": [
    {
      "filter": "datum.age_group != 'All ages'"
    }
  ],
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "age_group",
      "type": "nominal",
      "axis": { "labelAngle": -25 },
      "title": "Age Group"
    },
    "xOffset": {
      "field": "cause"
    },
    "y": {
      "field": "percent",
      "type": "quantitative",
      "title": "Percent of deaths"
    },
    "color": {
      "legend": { "orient": "bottom" },
      "field": "cause",
      "type": "nominal",
      "title": "Death Category",
      "scale": {
        "domain": [
          "Communicable, maternal, perinatal and nutritional conditions",
          "Noncommunicable diseases",
          "Injuries"
        ],
        "range": ["#1f77b4", "#1ba31e", "#731fb4"]
      }
    },
    "tooltip": [
      { "field": "country" },
      { "field": "age_group" },
      { "field": "cause" },
      { "field": "percent" },
      { "field": "deaths" }
    ]
  }
}
