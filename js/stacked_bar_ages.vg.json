{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 400,
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "title": "Amount of Deaths for each Age Group (2021)",
  "data": {
    "url": "https://raw.githubusercontent.com/lnic0029/FIT2179_A2/refs/heads/main/data/global_age_causes_2021.csv"
  },
  "transform": [
    {
      "filter": "datum.age_group != 'All ages'"
    }
  ],
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "age_group",
      "type": "nominal",
      "title": "Age Group",
      "sort": ["0-4", "5-14", "15-29", "30-49", "50-59", "60-69", "70+"],
      "axis": { "labelAngle": -25 }
    },
    "xOffset": {
      "field": "cause"
    },
    "y": {
      "field": "deaths",
      "type": "quantitative",
      "title": "Number of deaths (square root scale)",
      "scale": {
        "type": "sqrt"
      }
    },
    "color": {
      "legend": { "orient": "bottom" },
      "field": "cause",
      "type": "nominal",
      "title": "Death Category",
      "scale": {
        "domain": [
          "Communicable, maternal, perinatal and nutritional conditions",
          "Noncommunicable diseases",
          "Injuries"
        ],
        "range": ["#1f77b4", "#1ba31e", "#e4ca03"]
      }
    },
    "tooltip": [
      { "field": "country" },
      { "field": "age_group" },
      { "field": "cause" },
      { "field": "deaths" }
    ]
  }
}
