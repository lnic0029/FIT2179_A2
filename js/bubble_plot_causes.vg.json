{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 650,
  "height": 500,
  "title": "Cause-of-Death Composition Over Time",

  "data": {
    "url": "https://raw.githubusercontent.com/lnic0029/FIT2179_A2/refs/heads/main/data/merged_all_years_categories.csv"
  },
  "transform": [
    {
      "filter": "datum.sex === 'persons' && toNumber(datum.year) === year"
    },
    {
      "aggregate": [
        {
          "op": "sum",
          "field": "percentage_of_total_deaths",
          "as": "value"
        }
      ],
      "groupby": ["country", "year", "major_category"]
    },
    {
      "pivot": "major_category",
      "value": "value",
      "groupby": ["country", "year"]
    },
    {
      "calculate": "datum['Communicable, maternal, perinatal and nutritional conditions']",
      "as": "communicable"
    },
    {
      "calculate": "datum['Noncommunicable diseases']",
      "as": "noncommunicable"
    },
    {
      "calculate": "datum['Injuries']",
      "as": "injuries"
    },
    {
      "filter": "test(regexp(country_search, 'i'), datum.country) || country_search == ''"
    }
  ],

  "params": [
    {
      "name": "year",
      "value": 2000,
      "bind": {
        "input": "select",
        "options": [2000, 2015, 2019, 2020, 2021],
        "name": "Year: "
      }
    },
    {
      "name": "country_search",
      "value": "",
      "bind": {
        "input": "search",
        "placeholder": "Search country (e.g. aus, ang, arg)",
        "name": "Country Search: "
      }
    }
  ],

  "mark": {
    "type": "circle",
    "opacity": 0.75,
    "stroke": "black",
    "strokeWidth": 0.5
  },

  "encoding": {
    "x": {
      "field": "communicable",
      "type": "quantitative",
      "title": "Communicable %",
      "scale": {
        "domain": [0, 85]
      }
    },
    "y": {
      "field": "noncommunicable",
      "type": "quantitative",
      "title": "Noncommunicable %",
      "scale": {
        "domain": [0, 100]
      }
    },
    "size": {
      "field": "injuries",
      "type": "quantitative",
      "title": "Injuries %",
      "scale": {
        "domain": [0, 30]
      }
    },

    "color": {
      "field": "country",
      "type": "nominal",
      "legend": null
    },
    "tooltip": [
      { "field": "country", "type": "nominal", "title": "Country" },

      {
        "field": "communicable",
        "type": "quantitative",
        "title": "Communicable %"
      },
      {
        "field": "noncommunicable",
        "type": "quantitative",
        "title": "Noncommunicable %"
      },
      { "field": "injuries", "type": "quantitative", "title": "Injuries %" }
    ]
  }
}
